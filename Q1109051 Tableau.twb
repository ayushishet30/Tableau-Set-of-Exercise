    <dashboard name='From Student Engagement Behaviour to Academic Outcomes' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Tableau Book' fontsize='19' italic='false' underline='false'>From Student Engagement Behaviour to Academic Outcomes
</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='1594' />
        </style-rule>
