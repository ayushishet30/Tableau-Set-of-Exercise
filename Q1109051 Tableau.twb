            </zone>
            <zone h='90731' id='10' param='vert' removable='false' type-v2='layout-flow' w='99042' x='479' y='8445'>
              <zone h='90731' id='8' param='vert' removable='false' type-v2='layout-flow' w='99042' x='479' y='8445'>
                <zone h='90731' id='1' param='vert' removable='false' type-v2='layout-flow' w='99042' x='479' y='8445'>
                  <zone fixed-size='129' h='13285' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='99042' x='479' y='8445' />
                  <zone h='77446' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='99042' x='479' y='21730'>
                    <flipboard active-id='8' nav-type='caption' show-nav-arrows='true'>
                      <story-points>
                        <story-point caption='Introduction to the analytical objective and scope of the study.' captured-sheet='' id='1' />
                        <story-point caption='This dashboard provides a high-level overview of student engagement across modules and illustrates how academic outcomes vary by engagement level. Differences in engagement levels highlight early patterns associated with academic risk and success.' captured-sheet='Engagement Overview' id='2' />
                        <story-point caption='This view analyses individual student engagement behaviour based on learning consistency and interaction intensity, revealing distinct behavioural patterns across academic outcomes.&#10;&#10;' captured-sheet='Student Engagement Behaviour Map' id='4' />
                        <story-point caption='This dashboard summarises engagement behaviour profiles and success likelihood trends, demonstrating how engagement intensity and consistency influence academic performance and risk.&#10;&#10;' captured-sheet='Behaviour Profile MAP (Treemap)' id='5' />
                        <story-point caption='This comparison highlights differences in engagement distribution between at-risk and successful students, reinforcing behavioural patterns observed in prior analysis.' captured-sheet='At‑Risk vs Successful – Engagement Distribution' id='6' />
                        <story-point caption='Key Insights and Implications' captured-sheet='' id='7' />
                        <story-point caption='This view demonstrates execution of a Python-based engagement score using TabPy, confirming successful integration of external analytics within Tableau.' captured-sheet='TabPy-Computed Engagement Score by Academic Outcome' id='8' />
                      </story-points>
                    </flipboard>
                  </zone>
                </zone>
              </zone>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='27600' hidden='true' id='6' story-point-id='1' type-v2='text' w='97247' x='586' y='22760'>
          <formatted-text>
            <run fontalignment='0'>Æ&#10;</run>
            <run bold='true' fontalignment='0' fontcolor='#000000' fontsize='20'>Problem Context and Motivation</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#000000'>Student engagement plays a crucial role in academic success within online learning environments. This study examines student engagement behaviour and analyses how different engagement patterns relate to academic outcomes.</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='12976' hidden='true' id='16' story-point-id='7' type-v2='text' w='97726' x='838' y='22245'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#000000' fontsize='11'>The analysis shows a strong relationship between student engagement behaviour and academic outcomes, supporting the use of engagement analytics for early identification of at-risk learners.</run>
            <run fontalignment='0'>Æ&#10;</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='9887' id='17' story-point-id='8' type-v2='text' w='47935' x='3950' y='23893'>
