      <aliases enabled='yes' />
      <column caption='Engagement Level' datatype='string' name='[Calculation_0166026938859520]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [sum_click] &lt; 500 THEN &quot;Low Engagement&quot;&#13;&#10;ELSEIF [sum_click] &lt; 2000 THEN &quot;Medium Engagement&quot;&#13;&#10;ELSE &quot;High Engagement&quot;&#13;&#10;END' />
      </column>
      <column caption='Outcome Group' datatype='string' name='[Calculation_0166026954571778]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [final_result] = &quot;Fail&quot; OR [final_result] = &quot;Withdrawn&quot;&#13;&#10;THEN &quot;At Risk&quot;&#13;&#10;ELSE &quot;Successful&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Active Learning Days (Global)' datatype='real' name='[Calculation_0166026968694787]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG([date]) }' />
      </column>
      <column caption='Avg Total VLE Interactions (Global)' datatype='real' name='[Calculation_0166027042127876]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG([sum_click]) }' />
      </column>
      <column caption='Learner Behaviour Profile' datatype='string' name='[Calculation_0166027042402309]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [date] &gt;= [Calculation_0166026968694787]&#13;&#10;   AND [sum_click] &gt;= [Calculation_0166027042127876]&#13;&#10;THEN &quot;Consistently Engaged&quot;&#13;&#10;&#13;&#10;ELSEIF [date] &gt;= [Calculation_0166026968694787]&#13;&#10;   AND [sum_click] &lt; [Calculation_0166027042127876]&#13;&#10;THEN &quot;Passive Learners&quot;&#13;&#10;&#13;&#10;ELSEIF [date] &lt; [Calculation_0166026968694787]&#13;&#10;   AND [sum_click] &gt;= [Calculation_0166027042127876]&#13;&#10;THEN &quot;Crammers&quot;&#13;&#10;&#13;&#10;ELSE &quot;Disengaged&quot;&#13;&#10;END' />
      </column>
      <column caption='Engagement Intensity Bin' datatype='integer' name='[Calculation_0166027054194694]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT([sum_click] / 500) * 500' />
      </column>
      <column caption='Success Probability' datatype='real' name='[Calculation_0166027054415879]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Calculation_0166026954571778] = &quot;Successful&quot; THEN 1 ELSE 0 END&#13;&#10;) / COUNT([id_student])' />
      </column>
      <column caption='Basic Engagement Score (TabPy)' datatype='real' name='[Calculation_0166027071008776]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SCRIPT_REAL(&#13;&#10;&quot;&#13;&#10;return _arg1&#13;&#10;&quot;,&#13;&#10;AVG([sum_click])&#13;&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
