      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98352' id='14' param='vert' removable='false' type-v2='layout-flow' w='99042' x='479' y='824'>
